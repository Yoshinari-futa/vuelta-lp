{
  "name": "vuelta-lp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev -p 3000 --hostname 127.0.0.1",
    "dev:clean": "npm run clean && npm run dev",
    "dev:3001": "next dev -p 3001 --hostname 127.0.0.1",
    "dev:fresh": "bash -c 'lsof -ti :3000 | xargs kill -9 2>/dev/null; true' && npm run dev",
    "dev:lan": "next dev -p 3000 --hostname 0.0.0.0",
    "preview": "npm run build && npm run start",
    "build": "next build",
    "start": "next start -p 3000 --hostname 127.0.0.1",
    "lint": "next lint",
    "optimize-images": "node scripts/optimize-public-images.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "framer-motion": "^11.0.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
